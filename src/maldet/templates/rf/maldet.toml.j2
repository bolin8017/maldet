[detector]
name = "{{ name }}"
version = "0.1.0"
framework = "sklearn"
description = "{{ name }} (sklearn) — scaffolded by maldet scaffold"

[input]
binary_format = "elf"
required_sections = [".text"]
dataset_contract = "sample_csv"

[output]
task = "binary_classification"
classes = ["Malware", "Benign"]
positive_class = "Malware"
score_range = [0.0, 1.0]

[resources]
supports = ["cpu"]
recommended = "cpu"
min_memory_gib = 2
gpu_required = false

[lifecycle]
stages = ["train", "evaluate", "predict"]
supports_serving = false
supports_hpsweep = true
supports_distributed = false
supports_multinode = false

[artifacts]
model = { path = "model/", type = "dir" }
metrics = { path = "metrics.json", type = "file" }
predictions = { path = "predictions.csv", type = "file" }

[compat]
min_python = "3.12"
min_maldet = "1.0"
schema_version = 1

[stages.train]
reader = "maldet.builtins.readers:SampleCsvReader"
extractor = "{{ name }}.features:Text256Extractor"
model = "{{ name }}.models:make_rf"
trainer = "maldet.trainers.sklearn_trainer:SklearnTrainer"
evaluator = "maldet.evaluators.binary:BinaryClassification"
config_class = "{{ name }}.configs:TrainConfig"
params_schema = {}  # placeholder; populated by `maldet introspect-schema` (Task 1.4 / `maldet build`)

[stages.evaluate]
reader = "maldet.builtins.readers:SampleCsvReader"
extractor = "{{ name }}.features:Text256Extractor"
evaluator = "maldet.evaluators.binary:BinaryClassification"
config_class = "{{ name }}.configs:EvaluateConfig"
params_schema = {}  # placeholder; populated by `maldet introspect-schema` (Task 1.4 / `maldet build`)

[stages.predict]
reader = "maldet.builtins.readers:SampleCsvReader"
extractor = "{{ name }}.features:Text256Extractor"
predictor = "maldet.builtins.predictors:BatchPredictor"
config_class = "{{ name }}.configs:PredictConfig"
params_schema = {}  # placeholder; populated by `maldet introspect-schema` (Task 1.4 / `maldet build`)
